  const generateDescription = async (nameId: string, catId: string, descId: string, btnId: string) => {
    const nameVal = (document.getElementById(nameId) as HTMLInputElement).value.trim();
    const catVal = (document.getElementById(catId) as HTMLInputElement).value.trim();
    const descArea = document.getElementById(descId) as HTMLTextAreaElement;
    const btn = document.getElementById(btnId) as HTMLButtonElement;

    if (!nameVal) {
      toast("❌ Please enter a Food Name first.", "error");
      return;
    }

    let apiKey = "";
    const storedObf = localStorage.getItem("gemini_api_key_obf");
    if (storedObf) {
      apiKey = dec(storedObf);
    } else {
      apiKey = localStorage.getItem("gemini_api_key") || "";
    }

    if (!apiKey) {
      toast("❌ Please save your Gemini API Key in the Settings section first.", "error");
      switchTab("#section-settings");
      return;
    }

    btn.disabled = true;
    btn.textContent = "Writing...";

    try {
      const promptText = `Write a delicious, short one-sentence food description for: ${nameVal} ${catVal ? `(Category: ${catVal})` : ''}. Make it mouth-watering and concise (max 20 words). Do not include any introductory words, quotation marks, or leading text, just write the description.`;
      
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          contents: [{
            parts: [{ text: promptText }]
          }]
        })
      });

      if (!response.ok) {
        throw new Error(`HTTP Error ${response.status}`);
      }

      const result = await response.json();
      const text = result.candidates?.[0]?.content?.parts?.[0]?.text?.trim() || "";
      if (text) {
        descArea.value = text;
        toast("✨ AI Description generated!");
      } else {
        throw new Error("Empty response from Gemini model.");
      }
    } catch (err: any) {
      console.error(err);
      toast(`❌ Generation failed: ${err.message || err}`, "error");
    } finally {
      btn.disabled = false;
      btn.textContent = "🪄 AI Write";
    }
  };

  document.getElementById("ai-gen-desc-btn")?.addEventListener("click", () => {
    generateDescription("food-name", "food-category", "food-description", "ai-gen-desc-btn");
  });

  document.getElementById("edit-ai-gen-desc-btn")?.addEventListener("click", () => {
    generateDescription("edit-food-name", "edit-food-category", "edit-food-description", "edit-ai-gen-desc-btn");
  });

  // Mobile Sidebar Toggle Panel
  const sidebar = document.querySelector(".admin-sidebar");
  const toggleBtn = document.getElementById("sidebar-toggle-btn");
  const backdrop = document.getElementById("sidebar-backdrop");

  const openSidebar = () => {
    sidebar?.classList.add("open");
    if (backdrop) backdrop.style.display = "block";
    document.body.style.overflow = "hidden"; // Prevent background body scrolling
  };

  const closeSidebar = () => {
    sidebar?.classList.remove("open");
    if (backdrop) backdrop.style.display = "none";
    document.body.style.overflow = ""; // Restore scrolling
  };

  toggleBtn?.addEventListener("click", openSidebar);
  backdrop?.addEventListener("click", closeSidebar);

  // Close when clicking any menu link on mobile
  document.querySelectorAll(".sidebar-item").forEach(item => {
    item.addEventListener("click", () => {
      closeSidebar();
    });
  });

  // --- EDITOR ACCESS CONTROL MANAGEMENT ---
  async function loadAuthorizedEditors() {
    const listBody = document.getElementById("authorized-editors-list");
    if (!listBody) return;

    listBody.innerHTML = `<tr><td colspan="4" class="text-center">Loading authorized members...</td></tr>`;

    try {
      const snap = await getDocs(collection(db, "editors"));
      if (snap.empty) {
        listBody.innerHTML = `<tr><td colspan="4" class="text-center muted">No members authorized. Add one above!</td></tr>`;
        return;
      }

      listBody.innerHTML = "";
      snap.forEach(docSnap => {
        const ed = { id: docSnap.id, ...docSnap.data() };
        const row = document.createElement("tr");

        const role = ed.role || "editor";
        const roleLabel = role === "dev-admin" ? "💻 Dev Admin" : "✏️ Menu Editor";

        row.innerHTML = `
          <td><strong>${esc(ed.email)}</strong></td>
          <td><span class="badge" style="background:${role === 'dev-admin' ? '#60a5fa' : 'rgba(160,200,120,0.15)'}; color:${role === 'dev-admin' ? '#fff' : 'var(--text-2)'};">${roleLabel}</span></td>
          <td><span class="muted">${esc(ed.addedBy || "Admin")}</span></td>
          <td>
            <button class="btn btn-danger btn-sm remove-editor-btn" data-id="${ed.id}">🗑️ Remove</button>
          </td>`;
        listBody.appendChild(row);
      });

      // Bind removes
      document.querySelectorAll(".remove-editor-btn").forEach(btn => {
        btn.addEventListener("click", async (e) => {
          const id = (e.currentTarget as HTMLElement).getAttribute("data-id");
          if (id && confirm("Are you sure you want to remove authorization for this editor?")) {
            await handleRemoveEditor(id);
          }
        });
      });
    } catch (err) {
      listBody.innerHTML = `<tr><td colspan="4" class="text-center muted">Failed to load editors.</td></tr>`;
    }
  }

  async function handleRemoveEditor(id) {
    try {
      await deleteDoc(doc(db, "editors", id));
      toast("🗑️ Member authorization removed!");
      await Promise.all([
        loadAuthorizedEditors(),
        loadAdminUsers()
      ]);
    } catch(err) {
      toast("❌ Remove failed.", "error");
    }
  }

  const addEditorForm = document.getElementById("add-editor-form");
  if (addEditorForm) {
    addEditorForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = addEditorForm.querySelector("[type=submit]") as HTMLButtonElement;
      const emailInput = document.getElementById("new-editor-email") as HTMLInputElement;
      const emailVal = emailInput.value.trim().toLowerCase();
      const roleInput = document.getElementById("new-editor-role") as HTMLSelectElement;
      const roleVal = roleInput ? roleInput.value : "editor";

      if (!emailVal) return;

      submitBtn.disabled = true;
      submitBtn.textContent = "Adding...";

      try {
        const snap = await getDocs(collection(db, "editors"));
        let exists = false;
        snap.forEach(d => {
          if (d.data().email === emailVal) exists = true;
        });

        if (exists) {
          toast("❌ Email is already authorized!", "error");
        } else {
          await setDoc(doc(db, "editors", emailVal), {
            email: emailVal,
            role: roleVal,
            createdAt: new Date(),
            addedBy: auth.currentUser?.email || "Admin"
          });
          toast("✅ Authorized member added!");
          emailInput.value = "";
          await Promise.all([
            loadAuthorizedEditors(),
            loadAdminUsers()
          ]);
        }
      } catch (err) {
        toast("❌ Failed to authorize editor.", "error");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "➕ Add Member";
      }
    });
  }

  // --- SYSTEM MAINTENANCE MODE MANAGEMENT ---
  async function loadMaintenanceMode() {
    try {
      const docSnap = await getDoc(doc(db, "settings", "config"));
      if (docSnap.exists()) {
        const isMaint = docSnap.data().maintenanceMode || false;
        const chk = document.getElementById("maintenance-toggle") as HTMLInputElement;
        if (chk) chk.checked = isMaint;
      }
    } catch(err) {
      console.error("Failed to load maintenance mode status:", err);
    }
  }

  const saveMaintBtn = document.getElementById("save-maintenance-btn");
  saveMaintBtn?.addEventListener("click", async () => {
    const chk = document.getElementById("maintenance-toggle") as HTMLInputElement;
    const isMaint = chk ? chk.checked : false;

    saveMaintBtn.disabled = true;
    saveMaintBtn.textContent = "Saving...";

    try {
      await setDoc(doc(db, "settings", "config"), { maintenanceMode: isMaint }, { merge: true });
      toast(`🔧 Maintenance Mode ${isMaint ? "ENABLED" : "DISABLED"}!`);
    } catch(err) {
      toast("❌ Failed to save maintenance settings.", "error");
    } finally {
      saveMaintBtn.disabled = false;
      saveMaintBtn.textContent = "Save Settings";
    }
  });

  // --- USER ACCOUNT MANAGEMENT ---
  async function loadAdminUsers() {
    const tableBody = document.getElementById("admin-users-table");
    if (!tableBody) return;

    tableBody.innerHTML = `<tr><td colspan="5" class="text-center">Loading registered users...</td></tr>`;

    try {
      const [usersSnap, editorsSnap] = await Promise.all([
        getDocs(collection(db, "users")),
        getDocs(collection(db, "editors"))
      ]);

      const editorRoles = new Map(); // maps email -> role string
      const editorDocIds = new Map(); // maps email -> docId
      editorsSnap.forEach(d => {
        const email = d.data().email.toLowerCase();
        editorRoles.set(email, d.data().role || "editor");
        editorDocIds.set(email, d.id);
      });

      if (usersSnap.empty) {
        tableBody.innerHTML = `<tr><td colspan="5" class="text-center muted">No registered users synced.</td></tr>`;
        return;
      }

      tableBody.innerHTML = "";
      usersSnap.forEach(docSnap => {
        const u = docSnap.data();
        const email = u.email.toLowerCase();
        
        let roleLabel = "👤 Customer";
        let roleBadgeColor = "rgba(160,200,120,0.15)";
        let actionHtml = "";

        if (email === ADMIN_EMAIL) {
          roleLabel = "🛡️ Super Admin";
          roleBadgeColor = "#ef4444";
          actionHtml = `<span class="muted">Access Locked</span>`;
        } else if (editorRoles.has(email)) {
          const r = editorRoles.get(email);
          roleLabel = r === "dev-admin" ? "💻 Dev Admin" : "✏️ Menu Editor";
          roleBadgeColor = r === "dev-admin" ? "#60a5fa" : "#3b82f6";
          const docId = editorDocIds.get(email);
          actionHtml = `<button class="btn btn-danger btn-sm revoke-user-editor-btn" data-email="${email}" data-doc-id="${docId}">🗑️ Revoke Access</button>`;
        } else {
          roleLabel = "👤 Customer";
          roleBadgeColor = "rgba(160,200,120,0.15)";
          actionHtml = `<button class="btn btn-outline btn-sm grant-user-editor-btn" data-email="${email}">➕ Grant Access</button>`;
        }

        const lastLoginDate = u.lastLogin?.toDate ? u.lastLogin.toDate() : new Date();
        const dateStr = lastLoginDate.toLocaleString();

        const row = document.createElement("tr");
        row.innerHTML = `
          <td><strong>${esc(u.displayName || "Customer")}</strong></td>
          <td>${esc(u.email)}</td>
          <td><span class="muted">${dateStr}</span></td>
          <td><span class="badge" style="background:${roleBadgeColor}; color:${roleLabel === '👤 Customer' ? 'var(--text-2)' : '#fff'};">${roleLabel}</span></td>
          <td>${actionHtml}</td>`;
        tableBody.appendChild(row);
      });

      // Bind actions
      document.querySelectorAll(".grant-user-editor-btn").forEach(btn => {
        btn.addEventListener("click", async (e) => {
          const email = (e.currentTarget as HTMLElement).getAttribute("data-email");
          if (email) {
            const role = confirm(`Grant Dev Admin privileges to ${email}? (Select OK for Dev Admin, Cancel for Menu Editor)`) ? "dev-admin" : "editor";
            await grantEditorRole(email, role);
          }
        });
      });

      document.querySelectorAll(".revoke-user-editor-btn").forEach(btn => {
        btn.addEventListener("click", async (e) => {
          const docId = (e.currentTarget as HTMLElement).getAttribute("data-doc-id");
          if (docId) {
            await revokeEditorRole(docId);
          }
        });
      });

    } catch (err) {
      console.error(err);
      tableBody.innerHTML = `<tr><td colspan="5" class="text-center muted">Failed to load users database.</td></tr>`;
    }
  }

  async function grantEditorRole(email, role) {
    try {
      await setDoc(doc(db, "editors", email.toLowerCase()), {
        email: email.toLowerCase(),
        role: role,
        createdAt: new Date(),
        addedBy: auth.currentUser?.email || "Admin"
      });
      toast(`✅ Granted ${role === 'dev-admin' ? 'Dev Admin' : 'Menu Editor'} access to ${email}`);
      await Promise.all([
        loadAuthorizedEditors(),
        loadAdminUsers()
      ]);
    } catch(err) {
      toast("❌ Failed to grant permission.", "error");
    }
  }

  async function revokeEditorRole(docId) {
    try {
      await deleteDoc(doc(db, "editors", docId));
      toast(`🗑️ Permissions revoked.`);
      await Promise.all([
        loadAuthorizedEditors(),
        loadAdminUsers()
      ]);
    } catch(err) {
      toast("❌ Failed to revoke permission.", "error");
    }
  }
</script>
