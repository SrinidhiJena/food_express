  const setupFileHelper = (fileInputId: string, textInputId: string) => {
    const fileInp = document.getElementById(fileInputId) as HTMLInputElement;
    if (fileInp) {
      fileInp.addEventListener("change", () => {
        const file = fileInp.files?.[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = (e) => {
            const base64 = e.target?.result as string;
            const txtInp = document.getElementById(textInputId) as HTMLInputElement;
            if (txtInp) txtInp.value = base64;
            toast("📁 Image uploaded successfully!");
          };
          reader.readAsDataURL(file);
        }
      });
    }
  };

