  async function loadAdminOrders() {
    const tableBody = document.getElementById("admin-orders-table");
    if (!tableBody) return;

    tableBody.innerHTML = `<tr><td colspan="6" class="text-center">Loading orders...</td></tr>`;

    try {
      const q = query(collection(db, "orders"), orderBy("createdAt", "desc"));
      const snap = await getDocs(q);

      if (snap.empty) {
        tableBody.innerHTML = `<tr><td colspan="6" class="text-center muted">No orders found.</td></tr>`;
        return;
      }

      tableBody.innerHTML = "";
      snap.forEach(docSnap => {
        const o = { id: docSnap.id, ...docSnap.data() };
        const date = o.createdAt?.toDate?.()?.toLocaleDateString("en-IN") || "—";
        const row = document.createElement("tr");

        row.innerHTML = `
          <td><code>#${o.id.slice(-8).toUpperCase()}</code></td>
          <td>
            <strong>${esc(o.userName || '—')}</strong>
            <div style="font-size:0.75rem; color:var(--text-2); margin-top:0.25rem;">📞 ${esc(o.userPhone || '—')}</div>
          </td>
          <td>${(o.foodItems || []).map(i => `${esc(i.foodName)}×${i.quantity} <small style="color:var(--primary); font-weight:700;">(${esc(i.restaurant)})</small>`).join(", ")}</td>
          <td><strong>₹${Number(o.totalPrice).toFixed(2)}</strong></td>
          <td>
            <span class="category-badge status-${(o.orderStatus || 'Pending').toLowerCase().replace(' ', '-')}" style="padding: 4px 10px; border-radius: 99px; font-weight: 700; font-size: 0.75rem;">
              ${esc(o.orderStatus || 'Pending')}
            </span>
          </td>
          <td>
            <button class="btn btn-sm btn-outline view-order-btn" data-id="${o.id}">🔍 View Dispatch</button>
          </td>`;
        tableBody.appendChild(row);
      });

      // Bind view details action
      document.querySelectorAll(".view-order-btn").forEach(btn => {
        btn.addEventListener("click", (e) => {
          const id = (e.currentTarget as HTMLElement).getAttribute("data-id");
          if (id) {
