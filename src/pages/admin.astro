  const enc = (s) => btoa(s);
  const dec = (s) => { try { return atob(s); } catch { return ""; } };

  const refreshKeyUI = () => {
    const stored = localStorage.getItem("gemini_api_key_obf") || localStorage.getItem("gemini_api_key");
    if (stored) {
      if (apiKeyInput) {
        apiKeyInput.value = "••••••••••••••••••••••••••••••••";
