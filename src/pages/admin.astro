                        <div style="font-size: 0.8rem; font-weight: 700; color: var(--text-2); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.5px;">Customer Delivery Details</div>
                        <div style="background: var(--bg-2); padding: 0.75rem 1rem; border: 1px solid var(--border); border-radius: var(--r); font-size: 0.875rem; display: flex; flex-direction: column; gap: 0.35rem;">
                            <div>👤 <strong>Name:</strong> <span id="detail-cust-name">—</span></div>
