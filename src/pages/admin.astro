---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admin Panel — FoodExpress" hideHeaderFooter={true}>
    <style is:global>
      /* Local overrides because navbar is hidden */
      .admin-container {
        margin-top: 0 !important;
        padding-top: 0 !important;
        min-height: 100vh !important;
        min-height: 100dvh !important;
      }
      .admin-sidebar {
        top: 0 !important;
        bottom: 0 !important;
        height: 100vh !important;
        height: 100dvh !important;
        max-height: 100dvh !important;
        overflow: hidden !important;
        display: flex !important;
        flex-direction: column !important;
      }
      @media(max-width:900px) {
        .admin-mobile-header {
          top: 0 !important;
        }
        .admin-container {
          padding-top: 52px !important;
        }
        .admin-sidebar {
          top: 0 !important;
          height: 100dvh !important;
          max-height: 100dvh !important;
        }
      }
      /* Swiggy/Zomato style Pipeline progress styling */
      .pipeline-step {
        position: relative;
        text-align: center;
        flex: 1;
      }
      .pipeline-step::after {
        content: '';
        position: absolute;
        top: 6px;
        left: 50%;
        width: 100%;
        height: 2px;
        background: var(--border, #333);
        z-index: 1;
        transition: background 0.3s;
      }
      .pipeline-step:last-child::after {
        display: none;
      }
      .pipeline-step.completed::after,
      .pipeline-step.active::after {
        background: var(--primary, #4ade80);
      }
      .step-dot {
        position: relative;
        z-index: 2;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--border, #333);
        border: 2px solid var(--bg-card, #1a1a2e);
        margin: 0 auto 0.25rem;
        transition: all 0.3s ease;
      }
      .pipeline-step.active .step-dot {
        background: var(--primary, #4ade80);
        box-shadow: 0 0 8px var(--primary, #4ade80);
        transform: scale(1.2);
      }
      .pipeline-step.completed .step-dot {
        background: var(--primary, #4ade80);
      }
    </style>
    
    <main class="admin-wrap" id="admin-root">
        <!-- Access Denied or Loading state is managed by script -->
        <div class="loading-state" id="admin-loader">
            <div class="spinner"></div>
            <p>Verifying admin permissions…</p>
        </div>
        
        <div id="admin-content" style="display:none;" class="admin-container">
            <!-- Mobile Header Bar -->
            <div class="admin-mobile-header">
                <button id="sidebar-toggle-btn" class="mobile-toggle-btn" type="button" aria-label="Open menu">
                    <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                </button>
                <span style="font-weight: 800; font-size: 0.95rem; color: var(--text);">FoodExpress Ops Center</span>
            </div>

            <!-- Mobile Backdrop Overlay -->
            <div id="sidebar-backdrop" class="sidebar-backdrop" style="display:none;"></div>

            <!-- Left Sidebar (TakeoutFix Style) -->
            <aside class="admin-sidebar">
                <div class="sidebar-top">
                    <div style="display:flex; align-items:center; gap:0.75rem;">
                        <div class="sidebar-avatar-logo">F</div>
                        <div class="sidebar-title-group">
                            <span class="sidebar-brand">FoodExpress</span>
                            <span class="sidebar-subbrand">OPS CENTER</span>
                        </div>
                    </div>
                    <button class="sidebar-bell-btn" title="View alerts" onclick="alert('No new alerts.')" type="button">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                    </button>
                </div>

                <div class="sidebar-sections-scroller">
                    <!-- OPERATIONS SECTION -->
                    <div class="sidebar-section">
                        <div class="sidebar-section-header">OPERATIONS</div>
                        <ul class="sidebar-menu">
                            <li class="super-admin-only">
                                <a href="#section-stats" class="sidebar-item active">
                                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2.2" fill="none"><rect x="3" y="3" width="7" height="9" rx="1"></rect><rect x="14" y="3" width="7" height="5" rx="1"></rect><rect x="14" y="12" width="7" height="9" rx="1"></rect><rect x="3" y="16" width="7" height="5" rx="1"></rect></svg>
                                    Dashboard
                                </a>
                            </li>
                            <li>
                                <a href="#section-add-food" class="sidebar-item">
                                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2.2" fill="none"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
                                    Add Food Item
                                </a>
                            </li>
                            <li>
                                <a href="#section-manage-foods" class="sidebar-item">
                                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2.2" fill="none"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                                    Manage Menu
                                </a>
                            </li>
                            <li class="super-admin-only">
                                <a href="#section-manage-orders" class="sidebar-item">
                                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2.2" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                                    Active Orders
                                </a>
                            </li>
                            <li class="super-admin-only">
                                <a href="#section-users" class="sidebar-item">
                                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2.2" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                                    Manage Users
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- CONTENT SECTION -->
                    <div class="sidebar-section super-admin-only">
                        <div class="sidebar-section-header">CONTENT</div>
                        <ul class="sidebar-menu">
                            <li>
                                <a href="#mock-reviews" class="sidebar-item mock-link">
                                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2.2" fill="none"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                                    Reviews
                                </a>
                            </li>
                            <li>
                                <a href="#mock-statistics" class="sidebar-item mock-link">
                                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2.2" fill="none"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                                    Statistics
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- SYSTEM SECTION -->
                    <div class="sidebar-section">
                        <div class="sidebar-section-header">SYSTEM</div>
                        <ul class="sidebar-menu">
                            <li class="dev-admin-only">
                                <a href="#section-settings" class="sidebar-item">
                                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2.2" fill="none"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                    Keys & Secrets
                                </a>
                            </li>
                            <li class="super-admin-only">
                                <a href="#section-app-settings" class="sidebar-item">
                                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2.2" fill="none"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                                    Settings
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Bottom Open Website Link -->
                <div class="sidebar-footer" style="padding: 1.25rem;">
                    <a href="/" class="sidebar-footer-link">
                        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2.2" fill="none"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                        Open Website
                    </a>
                </div>
            </aside>

            <!-- Main Content Area -->
            <div class="admin-main-content">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 2rem; flex-wrap:wrap; gap:1rem;">
                    <div>
                        <h1 class="admin-title" id="admin-title-heading">Admin Dashboard</h1>
                        <p class="admin-subtitle" style="margin-bottom:0;">Manage FoodExpress foods, orders, and sales stats.</p>
                    </div>
                    <div style="display:flex; align-items:center; gap:0.75rem;">
                        <button id="seed-menu-btn" class="btn btn-outline" style="border-color: var(--primary); color: var(--primary); font-weight:700; margin:0;" title="Restores standard menu items if empty">✨ Load Sample Menu</button>
                        <button id="admin-top-logout-btn" class="btn btn-danger" style="margin:0; font-weight:700; display:flex; align-items:center; gap:0.4rem; padding: 0.5rem 1rem; border-radius: 8px;">
                            <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                            Sign Out
                        </button>
                    </div>
                </div>

                <!-- Stats Overview -->
                <section id="section-stats" class="admin-tab-content scroll-mt" style="margin-bottom: 2.5rem;">
                    <div class="stats-row">
                        <div class="stat-card">
                            <div class="stat-val" id="stat-foods">0</div>
                            <div class="stat-lbl">Active Foods</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-val" id="stat-orders">0</div>
                            <div class="stat-lbl">Total Orders</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-val" id="stat-revenue">₹0</div>
                            <div class="stat-lbl">Revenue</div>
                        </div>
                    </div>
                </section>

                <!-- Add Food Item Section -->
                <section id="section-add-food" class="admin-section admin-tab-content scroll-mt" style="margin-bottom: 2.5rem; display: none;">
                    <div class="admin-section-head">
                        <h2>Add New Food Item</h2>
                    </div>
                    <form id="add-food-form" class="add-food-form">
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="food-name">Food Name</label>
                                <input type="text" id="food-name" class="input" required placeholder="e.g. Garlic Bread">
                            </div>
                            <div class="form-group">
                                <label for="food-category">Category</label>
                                <select id="food-category" class="input" style="cursor:pointer;" required>
                                    <option value="" disabled selected>Select Category</option>
                                    <option value="Tiffin">🥞 Tiffins</option>
                                    <option value="Biryani">🍛 Biryanis</option>
                                    <option value="Haleem">🥘 Haleem</option>
                                    <option value="Curry">🍲 Curries</option>
                                    <option value="Starter">🍢 Starters</option>
                                    <option value="Dessert">🍮 Desserts</option>
                                    <option value="Combos">🎁 Combos</option>
                                    <option value="Breads">🍞 Breads</option>
                                    <option value="Beverages (Hot)">☕ Beverages (Hot)</option>
                                    <option value="Beverages (Cold)">🥤 Beverages (Cold)</option>
                                    <option value="Meals">🍱 Meals</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="food-restaurant">Restaurant Source</label>
                                <select id="food-restaurant" class="input" style="cursor:pointer;" required>
                                    <option value="" disabled selected>Select Restaurant</option>
                                    <option value="Shah Ghouse">Shah Ghouse</option>
                                    <option value="Paradise Biryani">Paradise Biryani</option>
                                    <option value="Irani Cafe">Irani Cafe</option>
                                    <option value="Chutneys">Chutneys</option>
                                    <option value="Pista House">Pista House</option>
                                    <option value="Mehfil Restaurant">Mehfil Restaurant</option>
                                    <option value="Burger King">Burger King</option>
                                    <option value="Subway">Subway</option>
                                    <option value="Bikanervala">Bikanervala</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="food-price">Price (₹)</label>
                                <input type="number" id="food-price" class="input" required min="1" placeholder="e.g. 149">
                            </div>
                            <div class="form-group">
                                <label for="food-image">Image URL / Upload / Paste</label>
                                <div style="display:flex; gap:0.5rem; align-items:center;">
                                    <input type="text" id="food-image" class="input" placeholder="Paste URL/Image or upload file..." style="flex:1;">
                                    <label class="btn btn-outline btn-sm" style="margin:0; cursor:pointer; padding: 0.5rem 1rem; flex-shrink:0;">
                                        📁 Upload
                                        <input type="file" id="food-image-file" accept="image/*" style="display:none;">
                                    </label>
                                    <button type="button" id="food-image-paste-btn" class="btn btn-outline btn-sm" style="margin:0; padding: 0.5rem 1rem; flex-shrink:0;">
                                        📋 Paste
                                    </button>
                                </div>
                                <!-- Live Image Preview -->
                                <div style="margin-top:0.5rem; display:flex; align-items:center; gap:0.75rem;">
                                    <img id="food-image-preview" src="images/pizza.jpg" style="width:55px; height:55px; object-fit:cover; border-radius:8px; border:1px solid var(--border); display:none;" onerror="this.src='images/pizza.jpg'">
                                    <span id="food-image-preview-label" style="font-size:0.75rem; color:var(--text-2); display:none;">✨ Live Preview</span>
                                </div>
                                <div class="preset-links-wrap" style="margin-top: 0.5rem;">
                                    <span style="font-size: 0.75rem; color: var(--text-2);">Presets:</span>
                                    <button type="button" class="preset-btn add-preset-btn" data-url="https://images.unsplash.com/photo-1633945274405-b6c8069047b0?auto=format&fit=crop&w=600&q=80">Biryani</button>
                                    <button type="button" class="preset-btn add-preset-btn" data-url="https://images.unsplash.com/photo-1505253716362-afaea1d3d1af?auto=format&fit=crop&w=600&q=80">Dosa</button>
                                    <button type="button" class="preset-btn add-preset-btn" data-url="https://images.unsplash.com/photo-1680373854583-lY2m5lxJrmQ?auto=format&fit=crop&w=600&q=80">Idli</button>
                                    <button type="button" class="preset-btn add-preset-btn" data-url="images/puri_bhaji.png">Puri Bhaji</button>
                                    <button type="button" class="preset-btn add-preset-btn" data-url="images/biryani_combo.png">Biryani Combo</button>
                                    <button type="button" class="preset-btn add-preset-btn" data-url="images/chai_bun_combo.png">Chai Combo</button>
                                </div>
                            </div>
                        </div>
                        <div class="form-group" style="margin-top: 1rem;">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 0.5rem;">
                                <label for="food-description" style="margin:0;">Description</label>
                                <button type="button" id="ai-gen-desc-btn" class="btn btn-outline btn-sm" style="padding:2px 8px; font-size:0.75rem; margin:0;" title="Write description using Gemini AI">🪄 AI Write</button>
                            </div>
                            <textarea id="food-description" class="input" required placeholder="Describe the item..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary" style="margin-top: 1rem;">+ Add Food Item</button>
                    </form>
                </section>

                <!-- Manage Foods Section -->
                <section id="section-manage-foods" class="admin-section admin-tab-content scroll-mt" style="margin-bottom: 2.5rem; display: none;">
                    <div class="admin-section-head">
                        <h2>Manage Food Items</h2>
                    </div>
                    <div class="admin-table-wrap">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Image</th>
                                    <th>Name</th>
                                    <th>Category</th>
                                    <th>Price</th>
                                    <th>Description</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="admin-foods-table">
                                <!-- Loaded dynamically -->
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- Manage Orders Section -->
                <section id="section-manage-orders" class="admin-section admin-tab-content scroll-mt" style="margin-bottom: 2.5rem; display: none;">
                    <div class="admin-section-head">
                        <h2>Manage Orders</h2>
                    </div>
                    <div class="admin-table-wrap">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer Email</th>
                                    <th>Items</th>
                                    <th>Total Price</th>
                                    <th>Order Status</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody id="admin-orders-table">
                                <!-- Loaded dynamically -->
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- Gemini AI Settings Section -->
                <section id="section-settings" class="admin-section admin-tab-content scroll-mt" style="display: none;">
                    <div class="admin-section-head">
                        <h2>🤖 Gemini AI Keys</h2>
                    </div>
                    
                    <!-- Gemini Config -->
                    <div style="padding: 1.5rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-lg); box-shadow: var(--shadow-card);">
                        <h3 style="font-size: 1.1rem; font-weight:800; color: var(--text); margin-bottom: 0.5rem;">🪄 Gemini Description Generator</h3>
                        <p style="margin-bottom: 1.25rem; color: var(--text-2); font-size: 0.9rem; line-height: 1.5;">
                            Save your Google Gemini API Key locally in your browser. This enables the <strong>🪄 AI Write</strong> description helper on both Add and Edit food item panels.
                        </p>
                        <div class="form-group">
                            <label for="gemini-api-key" style="font-weight:700;">Gemini API Key</label>
                            <div style="display:flex; gap:0.5rem; align-items:center; margin-top:0.5rem;">
                                <input type="password" id="gemini-api-key" class="input" placeholder="Enter your API key here (AIzaSy...)" style="flex:1;">
                                <button type="button" id="save-api-key-btn" class="btn btn-primary btn-sm" style="margin:0;">Save Key</button>
                                <button type="button" id="rotate-api-key-btn" class="btn btn-outline btn-sm" style="margin:0; display:none;">🔄 Rotate Key</button>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- App Settings Section -->
                <section id="section-app-settings" class="admin-section admin-tab-content scroll-mt" style="display: none;">
                    <div class="admin-section-head">
                        <h2>⚙️ Operations Settings</h2>
                    </div>
                    
                    <!-- Editors Management Config -->
                    <div style="padding: 1.5rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-lg); box-shadow: var(--shadow-card); margin-bottom: 2rem;">
                        <h3 style="font-size: 1.1rem; font-weight:800; color: var(--text); margin-bottom: 0.5rem;">👥 Authorized Menu Editors</h3>
                        <p style="margin-bottom: 1.25rem; color: var(--text-2); font-size: 0.9rem; line-height: 1.5;">
                            Manage team members who are authorized to access the <strong>✏️ Edit Menu</strong> page.
                        </p>
                        
                        <form id="add-editor-form" style="display:flex; gap:0.5rem; align-items:center; margin-bottom: 1.5rem; flex-wrap: wrap;">
                            <input type="email" id="new-editor-email" class="input" placeholder="e.g. editor@foodexpress.com" style="flex:1; min-width: 200px;" required>
                            <select id="new-editor-role" class="input" style="width: auto; min-width: 150px;" required>
                                <option value="editor" selected>✏️ Menu Editor</option>
                                <option value="dev-admin">💻 Dev Admin</option>
                            </select>
                            <button type="submit" class="btn btn-primary btn-sm" style="margin:0;">➕ Add Member</button>
                        </form>

                        <div class="admin-table-wrap" style="margin-top:1rem; border-radius: var(--r);">
                            <table class="admin-table" style="font-size: 0.85rem;">
                                <thead>
                                    <tr>
                                        <th>Email Address</th>
                                        <th>Role</th>
                                        <th>Added By</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="authorized-editors-list">
                                    <tr><td colspan="3" class="text-center">Loading authorized members...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- System Maintenance Mode Config -->
                    <div style="padding: 1.5rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-lg); box-shadow: var(--shadow-card);">
                        <h3 style="font-size: 1.1rem; font-weight:800; color: var(--text); margin-bottom: 0.5rem;">🔧 Maintenance Mode</h3>
                        <p style="margin-bottom: 1.25rem; color: var(--text-2); font-size: 0.9rem; line-height: 1.5;">
                            When enabled, regular website visitors will be blocked by an "Under Maintenance" overlay page. Admins and authorized editors bypass this block to continue building.
                        </p>
                        
                        <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; margin-top:1rem;">
