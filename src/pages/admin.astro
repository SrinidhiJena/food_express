        <!-- Order Detail Modal (Swiggy/Zomato style Partner App Panel) -->
        <div id="order-detail-modal" class="modal-backdrop" style="display:none;">
            <div class="modal-card" style="max-width: 600px; width: 100%;">
                <div class="modal-header" style="border-bottom: 1px solid var(--border); padding-bottom: 0.75rem;">
                    <div>
                        <h3 style="margin: 0; font-size: 1.2rem;">📋 Swiggy/Zomato Dispatch Dashboard</h3>
                        <span id="detail-order-id" style="font-size: 0.8rem; color: var(--text-2); font-family: monospace; font-weight:700;">Order ID: #—</span>
