          </style>
        </head>
        <body>
          <div class="header">
            <div class="brand">🍔 FoodExpress</div>
            <div style="font-size: 12px; margin-top: 5px; color: #666;">Online Food Marketplace Middleman Invoice</div>
          </div>
          <div class="info-grid">
