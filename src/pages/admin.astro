    const inp = document.getElementById(inputId) as HTMLInputElement;
    const img = document.getElementById(imgId) as HTMLImageElement;
    const lbl = document.getElementById(labelId) as HTMLElement;

    if (!inp || !img || !lbl) return;

    const update = () => {
      const val = inp.value.trim();
      if (val) {
        img.src = val;
        img.style.display = "block";
        lbl.style.display = "block";
      } else {
        img.style.display = "none";
        lbl.style.display = "none";
      }
    };

    inp.value = ""; // start empty
    inp.addEventListener("input", update);
    inp.addEventListener("change", update);
    
    // Check periodically for presets/uploads programmatical changes
    setInterval(update, 400);
  };

