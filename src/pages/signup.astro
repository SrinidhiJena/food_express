---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sign Up — FoodExpress">
    <div class="auth-wrap">
        <div class="auth-card">
            <div class="auth-logo">🌿 FoodExpress</div>
            <h2>Create Account</h2>
            <p class="auth-sub">Sign up to get fresh meals delivered</p>
            <div id="error-container"></div>
            <form id="signup-form" class="auth-form">
                <input type="text" id="name" class="input" placeholder="Full name" required autocomplete="name">
                <input type="email" id="email" class="input" placeholder="Email address" required autocomplete="email">
                <input type="password" id="password" class="input" placeholder="Password (6+ characters)" required autocomplete="new-password">
                <input type="password" id="confirm-password" class="input" placeholder="Confirm password" required autocomplete="new-password">
                <button type="submit" class="btn btn-primary" style="width: 100%;">Create Account →</button>
            </form>
            <div class="divider">or</div>
            <button class="btn-google" id="google-btn">
                <svg viewBox="0 0 24 24">
                    <path fill="#EA4335" d="M12 5.04c1.62 0 3.08.56 4.22 1.65l3.15-3.15C17.45 1.68 14.92 1 12 1 7.37 1 3.4 3.65 1.45 7.52l3.79 2.94C6.18 7.36 8.87 5.04 12 5.04z"/>
                    <path fill="#4285F4" d="M23.49 12.27c0-.81-.07-1.59-.2-2.36H12v4.51h6.46c-.28 1.48-1.12 2.74-2.38 3.59l3.7 2.87c2.16-1.99 3.41-4.91 3.41-8.61z"/>
                    <path fill="#FBBC05" d="M5.24 14.54c-.24-.72-.38-1.49-.38-2.29s.14-1.57.38-2.29L1.45 7.02C.52 8.89 0 10.98 0 13s.52 4.11 1.45 5.98l3.79-2.94-.00-.50z"/>
                    <path fill="#34A853" d="M12 23c3.24 0 5.97-1.07 7.96-2.91l-3.7-2.87c-1.03.69-2.34 1.1-3.96 1.1-3.13 0-5.82-2.32-6.76-5.42L1.45 15.84C3.4 19.71 7.37 22.3 12 23z"/>
                </svg>
                Continue with Google
            </button>
            <div class="auth-footer">
                Already have an account? <a href="/login">Login</a>
            </div>
        </div>
    </div>
</Layout>

<script>
  import { auth, googleProvider } from '../scripts/firebaseApp.js';
  import { createUserWithEmailAndPassword, updateProfile, signInWithPopup } from 'firebase/auth';

  const signupForm = document.getElementById("signup-form");
  const googleBtn = document.getElementById("google-btn");
  const errorContainer = document.getElementById("error-container");

  function showError(msg) {
    if (!errorContainer) return;
    errorContainer.innerHTML = `<div class="auth-error">${msg}</div>`;
    setTimeout(() => {
      errorContainer.innerHTML = "";
    }, 5000);
  }

  const getFriendlyMessage = (code) => {
    switch (code) {
      case "auth/email-already-in-use": return "Email already registered.";
      case "auth/weak-password": return "Password must be 6+ characters.";
      case "auth/invalid-email": return "Invalid email.";
      case "auth/popup-closed-by-user": return "Google sign-up popup was closed.";
      case "auth/network-request-failed": return "Network connection error.";
      default: return "Registration failed. Please try again.";
    }
  };

  if (signupForm) {
    signupForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const nameVal = (document.getElementById("name") as HTMLInputElement).value.trim();
      const emailVal = (document.getElementById("email") as HTMLInputElement).value.trim();
      const passwordVal = (document.getElementById("password") as HTMLInputElement).value;
      const confirmPasswordVal = (document.getElementById("confirm-password") as HTMLInputElement).value;
      const submitBtn = signupForm.querySelector("[type=submit]") as HTMLButtonElement;

      if (passwordVal !== confirmPasswordVal) {
        showError("Passwords do not match!");
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = "Creating…";

      if (!emailVal.toLowerCase().endsWith("@gmail.com")) {
        showError("Only @gmail.com email addresses are allowed.");
        submitBtn.disabled = false;
        submitBtn.textContent = "Create Account →";
        return;
      }

      try {
        const cred = await createUserWithEmailAndPassword(auth, emailVal, passwordVal);
        await updateProfile(cred.user, { displayName: nameVal });
        window.location.href = "/";
      } catch (err: any) {
        showError(getFriendlyMessage(err.code));
        submitBtn.disabled = false;
        submitBtn.textContent = "Create Account →";
      }
    });
  }

  if (googleBtn) {
    googleBtn.addEventListener("click", async () => {
      try {
        await signInWithPopup(auth, googleProvider);
        window.location.href = "/";
      } catch (err: any) {
        showError(getFriendlyMessage(err.code));
      }
    });
  }
</script>
