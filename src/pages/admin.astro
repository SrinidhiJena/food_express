</Layout>

<script>
  import { auth, db } from '../scripts/firebaseApp.js';
  import { collection, getDocs, doc, addDoc, updateDoc, deleteDoc, query, orderBy, getDoc, setDoc } from 'firebase/firestore';
  import { onAuthStateChanged, signOut } from 'firebase/auth';

  const ADMIN_EMAIL = "srinidhijena@gmail.com";
  const esc = (s) => !s ? "" : String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;");

  function toast(msg, type = "success") {
    document.getElementById("app-toast")?.remove();
    const t = document.createElement("div");
    t.id = "app-toast";
    t.className = `app-toast toast-${type}`;
    t.textContent = msg;
    document.body.appendChild(t);
    requestAnimationFrame(() => t.classList.add("show"));
    setTimeout(() => {
      t.classList.remove("show");
      setTimeout(() => t.remove(), 400);
    }, 3000);
  }

  // Auth checker
  onAuthStateChanged(auth, async (user) => {
    const loader = document.getElementById("admin-loader");
    const content = document.getElementById("admin-content");
    const root = document.getElementById("admin-root");
    
    if (!root) return;

    if (!user) {
      if (loader) loader.remove();
      root.innerHTML = `
        <div class="access-denied">
          <div class="denied-icon">🔒</div>
          <h2>Access Denied</h2>
          <p>Please sign in first to access the dashboard.</p>
          <a href="/login" class="btn btn-primary">Sign In</a>
        </div>`;
      return;
    }

    let role = ""; // "super-admin", "dev-admin", or "editor"

    if (user.email === ADMIN_EMAIL) {
      role = "super-admin";
    } else {
      try {
        const snap = await getDocs(collection(db, "editors"));
        snap.forEach(d => {
          if (d.data().email === user.email.toLowerCase()) {
            role = d.data().role || "editor";
          }
        });
      } catch (err) {
        console.error("Failed to fetch user permissions:", err);
      }
    }

    if (!role) {
      if (loader) loader.remove();
      root.innerHTML = `
        <div class="access-denied">
          <div class="denied-icon">🔒</div>
          <h2>Access Denied</h2>
          <p>You do not have administrative or editor permissions to access this page.</p>
          <a href="/" class="btn btn-primary">Go Home</a>
        </div>`;
      return;
    }

    // Role-based visibility toggle
    const titleHeading = document.getElementById("admin-title-heading");
    if (role === "editor") {
      if (titleHeading) titleHeading.textContent = "Menu Editor Panel";
      document.querySelectorAll(".super-admin-only, .dev-admin-only").forEach(el => {
        (el as HTMLElement).style.display = "none";
      });
      // Force redirect to menu management if current tab is restricted
      const hash = window.location.hash;
      if (!hash || ["#section-stats", "#section-manage-orders", "#section-users", "#section-app-settings", "#section-settings"].includes(hash)) {
        switchTab("#section-manage-foods");
      }
    } else if (role === "dev-admin") {
      if (titleHeading) titleHeading.textContent = "Developer Admin Panel";
      document.querySelectorAll(".super-admin-only").forEach(el => {
        (el as HTMLElement).style.display = "none";
      });
      document.querySelectorAll(".dev-admin-only").forEach(el => {
        (el as HTMLElement).style.display = "";
      });
      // Force redirect to menu management if current tab is restricted
      const hash = window.location.hash;
      if (!hash || ["#section-stats", "#section-manage-orders", "#section-users", "#section-app-settings"].includes(hash)) {
        switchTab("#section-manage-foods");
      }
    } else {
      // Super Admin
      if (titleHeading) titleHeading.textContent = "Super Admin Dashboard";
      document.querySelectorAll(".super-admin-only, .dev-admin-only").forEach(el => {
        (el as HTMLElement).style.display = "";
      });
      // Default to stats tab if no hash is set
      const hash = window.location.hash;
      if (!hash) {
        switchTab("#section-stats");
      } else {
        switchTab(hash);
      }
    }

    // Is Authorized
    if (loader) loader.style.display = "none";
    if (content) content.style.display = "block";

    // Load Data
    await loadAdminDashboard(role);
  });

  async function loadAdminDashboard(role) {
    if (role === "super-admin") {
      await Promise.all([
        loadStats(),
        loadAdminFoods(),
        loadAdminOrders(),
        loadAuthorizedEditors(),
        loadMaintenanceMode(),
        loadAdminUsers()
      ]);
    } else {
      // Dev Admin or Editor (Menu management only)
      await Promise.all([
        loadAdminFoods()
      ]);
    }
  }

  async function loadStats() {
    try {
      const [foodsSnap, ordersSnap] = await Promise.all([
        getDocs(collection(db, "foods")),
        getDocs(collection(db, "orders"))
      ]);

      const activeFoods = foodsSnap.size;
      const totalOrders = ordersSnap.size;
      let revenue = 0;
      ordersSnap.forEach(docSnap => {
        revenue += (docSnap.data().totalPrice || 0);
      });

      const setVal = (id, val) => {
        const el = document.getElementById(id);
        if (el) el.textContent = val;
      };

      setVal("stat-foods", String(activeFoods));
      setVal("stat-orders", String(totalOrders));
      setVal("stat-revenue", `₹${Number(revenue).toFixed(2)}`);
    } catch(err) {
      console.error(err);
    }
  }

  async function loadAdminFoods() {
    const tableBody = document.getElementById("admin-foods-table");
    if (!tableBody) return;

    tableBody.innerHTML = `<tr><td colspan="6" class="text-center">Loading foods...</td></tr>`;

    try {
      const snap = await getDocs(collection(db, "foods"));
      if (snap.empty) {
        tableBody.innerHTML = `<tr><td colspan="6" class="text-center muted">No foods found. Add one above.</td></tr>`;
        return;
      }

      tableBody.innerHTML = "";
      snap.forEach(docSnap => {
        const f = { id: docSnap.id, ...docSnap.data() };
        const row = document.createElement("tr");
        row.id = `fr-${f.id}`;
        row.innerHTML = `
          <td><img src="${esc(f.image || 'images/pizza.jpg')}" class="tbl-img" onerror="this.src='images/pizza.jpg'"></td>
          <td>
            <strong>${esc(f.foodName)}</strong>
            <div style="font-size:0.75rem; color:var(--text-2); margin-top:0.25rem;">👨‍🍳 ${esc(f.restaurant || 'FoodExpress Special')}</div>
          </td>
          <td><span class="category-badge">${esc(f.category)}</span></td>
          <td>
            <span class="price-val">₹${Number(f.price).toFixed(2)}</span>
          </td>
          <td class="desc-cell">${esc(f.description).slice(0, 50)}...</td>
          <td>
            <div class="row-actions">
              <button class="btn btn-sm btn-outline edit-food-btn" data-id="${f.id}">✏️ Edit</button>
              <button class="btn btn-sm btn-danger del-food-btn" data-id="${f.id}">🗑️</button>
            </div>
          </td>`;
        tableBody.appendChild(row);
      });

      // Bind actions
      document.querySelectorAll(".edit-food-btn").forEach(btn => {
        btn.addEventListener("click", (e) => {
          const id = (e.target as HTMLElement).getAttribute("data-id");
          if (id) {
            const docSnap = snap.docs.find(d => d.id === id);
            if (docSnap) {
              openEditModal(id, docSnap.data());
            }
          }
        });
      });

      document.querySelectorAll(".del-food-btn").forEach(btn => {
        btn.addEventListener("click", (e) => {
          const id = (e.target as HTMLElement).getAttribute("data-id");
          if (id) handleDeleteFood(id);
        });
      });
    } catch(err) {
      tableBody.innerHTML = `<tr><td colspan="6" class="text-center muted">Failed to load foods.</td></tr>`;
    }
  }

  async function handleDeleteFood(id) {
    if (!confirm("Are you sure you want to delete this food item?")) return;
    try {
      await deleteDoc(doc(db, "foods", id));
      document.getElementById(`fr-${id}`)?.remove();
      toast("🗑️ Food item deleted.");
      await loadStats();
    } catch(err) {
      toast("❌ Delete failed.", "error");
    }
  }

  let activeOrderDetailId = "";
  let activeOrderDetailData: any = null;

  function updatePipelineTracker(status: string) {
    const steps = ["Pending", "Preparing", "On the Way", "Delivered"];
    const statusIndex = steps.indexOf(status);
    
    steps.forEach((s, idx) => {
      const stepEl = document.getElementById(`step-${s}`);
      if (stepEl) {
        stepEl.classList.remove("active", "completed");
        const dot = stepEl.querySelector(".step-dot");
        const text = stepEl.querySelector("div:last-child");
        
        if (idx === statusIndex) {
          stepEl.classList.add("active");
          if (dot) (dot as HTMLElement).style.background = "var(--primary)";
          if (text) (text as HTMLElement).style.color = "var(--text)";
        } else if (idx < statusIndex) {
          stepEl.classList.add("completed");
          if (dot) (dot as HTMLElement).style.background = "var(--primary)";
          if (text) (text as HTMLElement).style.color = "var(--primary)";
        } else {
          if (dot) (dot as HTMLElement).style.background = "var(--border)";
          if (text) (text as HTMLElement).style.color = "var(--text-2)";
        }
      }
    });
  }

  function openOrderDetail(id: string, o: any) {
    activeOrderDetailId = id;
    activeOrderDetailData = o;

    const modal = document.getElementById("order-detail-modal");
    (document.getElementById("detail-order-id") as HTMLElement).textContent = `Order ID: #${id.toUpperCase()}`;
    (document.getElementById("detail-cust-name") as HTMLElement).textContent = o.userName || "—";
    (document.getElementById("detail-cust-phone") as HTMLElement).textContent = o.userPhone || "—";
    (document.getElementById("detail-cust-email") as HTMLElement).textContent = o.userEmail || "—";
    (document.getElementById("detail-cust-address") as HTMLElement).textContent = o.address || "—";
    (document.getElementById("detail-cust-payment") as HTMLElement).textContent = o.paymentMethod || "Cash on Delivery";
    (document.getElementById("detail-grand-total") as HTMLElement).textContent = `₹${Number(o.totalPrice).toFixed(2)}`;
    (document.getElementById("detail-status-select") as HTMLSelectElement).value = o.orderStatus || "Pending";

    updatePipelineTracker(o.orderStatus || "Pending");

    const tbody = document.getElementById("detail-items-body");
    if (tbody) {
      tbody.innerHTML = (o.foodItems || []).map((i: any) => {
        const sub = Number(i.price) * Number(i.quantity);
        return `
          <tr>
            <td><strong>${esc(i.foodName)}</strong></td>
