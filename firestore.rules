rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin check ─────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'srinidhijena@gmail.com';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    function isAuthorizedEditor() {
      return request.auth != null && (
        isAdmin() ||
        exists(/databases/$(database)/documents/editors/$(request.auth.token.email))
      );
    }

    // ── Foods ────────────────────────────────────────────────
    // Anyone can read; admin and authorized editors can write
    match /foods/{foodId} {
      allow read: if true;
      allow create, update, delete: if isAuthorizedEditor();
    }

    // ── Orders ──────────────────────────────────────────────
    // Users can create their own; read their own; admin can read/update all
    match /orders/{orderId} {
      allow create: if isLoggedIn();
      allow read:   if isLoggedIn() &&
                      (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Editors ──────────────────────────────────────────────
    // Logged in users can read to verify edit rights; only admin can write
    match /editors/{editorId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── Users ────────────────────────────────────────────────
    // Any logged-in user can update their own profile; admin can read/write all
    match /users/{userId} {
      allow read, write: if isLoggedIn() && (request.auth.uid == userId || isAdmin());
    }

    // ── Settings ─────────────────────────────────────────────
    // Anyone can read settings (e.g. maintenance status); only admin can write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
